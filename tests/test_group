# We use permutations as group elements. Identity does NOT depend on instance data,
# which matches how Group._build_group_cayley calls gtype.identity().

class SymOpS3:
    """Permutation on 3 points. Composition (self * other) := self * other."""
    __slots__ = ("perm",)

    def __init__(self, perm):
        self.perm = tuple(perm)  # e.g., (0,1,2) for identity

    @classmethod
    def identity(cls):
        return cls((0, 1, 2))

    def inv(self):
        r = [None]*3
        for i, p in enumerate(self.perm):
            r[p] = i
        return self.__class__(tuple(r))

    def __mul__(self, other: "SymOpS3"):
        # compose: self ∘ other
        p, q = self.perm, other.perm
        return self.__class__(tuple(p[q[i]] for i in range(3)))

    def __eq__(self, other):
        return isinstance(other, self.__class__) and self.perm == other.perm

    def __hash__(self):
        return hash(("S3", self.perm))

    def __repr__(self):
        return f"S3{self.perm}"

    def to_str(self):
        # labels used in adjacency; must match the labels created when building the graph
        return repr(self)


class SymOpC4:
    """Permutation on 4 points (use for C4 generated by rotation r)."""
    __slots__ = ("perm",)

    def __init__(self, perm):
        self.perm = tuple(perm)

    @classmethod
    def identity(cls):
        return cls((0, 1, 2, 3))

    def inv(self):
        r = [None]*4
        for i, p in enumerate(self.perm):
            r[p] = i
        return self.__class__(tuple(r))

    def __mul__(self, other: "SymOpC4"):
        p, q = self.perm, other.perm
        return self.__class__(tuple(p[q[i]] for i in range(4)))

    def __eq__(self, other):
        return isinstance(other, self.__class__) and self.perm == other.perm

    def __hash__(self):
        return hash(("C4", self.perm))

    def __repr__(self):
        return f"C4{self.perm}"

    def to_str(self):
        return repr(self)


