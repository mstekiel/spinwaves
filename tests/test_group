def test_group_repr_and_order_s3(s3_generators):
    e, s, t = s3_generators
    # Give a list with duplicates and an explicit identity; Group should dedupe and drop identity
    G = Group([s, t, s, e], name="S3")
    assert "S3" in repr(G)
    assert G.order == 6  # S3 has 6 elements

def test_generators_set_identity_removed(s3_generators):
    e, s, t = s3_generators
    G = Group([s, t, e])
    # Identity should not be in generators; uniqueness enforced by set()
    assert all(g != e for g in G._generators)
    assert len(G._generators) in (1, 2)  # depending on hash order, but identity is gone

def test_mult_table_matches_operation_s3(s3_generators):
    _, s, t = s3_generators
    G = Group([s, t])

    # multiplication table consistency: for all a,b in operations, table[(a,b)] == a*b
    for a in G._operations:
        for b in G._operations:
            assert G._mult_table[(a, b)] == (a * b)

def test_adjacency_has_right_labels_and_vertices_s3(s3_generators):
    _, s, t = s3_generators
    G = Group([s, t])

    # Each vertex should have out-degree equal to number of steps used when building:
    # steps = set(gens u gens^{-1}) \ {identity}. Here s and t are involutions, so steps = {s,t}.
    steps = {s, t}
    for u, edges in G._adjacency.items():
        # all labels among steps, all endpoints in operations
        assert all(lbl in steps for lbl, v in edges)
        assert all(v in G._operations for _, v in edges)
        # exactly two edges per node (s and t)
        assert len(edges) == 2

def test_adjacency_tensor_keys_are_generators_and_shapes_s3(s3_generators):
    _, s, t = s3_generators
    G = Group([s, t])

    mats = G._adjacency_tensor
    # Keys are the generator objects
    assert set(mats.keys()) == set(G._generators)
    # All slices have shape (n, n)
    n = G.order
    assert all(M.shape == (n, n) for M in mats.values())

    # Since s, t are involutions, each slice is a permutation matrix: one "1" per row.
    for gen, M in mats.items():
        row_sums = M.sum(axis=1)
        assert np.all(row_sums == 1), f"Row sums for {gen} should be 1 in S3"

def test_adjacency_matrix_equals_sum_of_slices_s3(s3_generators):
    _, s, t = s3_generators
    G = Group([s, t])

    # By construction
    expected = np.add.reduce([M for M in G._adjacency_tensor.values()]).astype(int)
    assert np.array_equal(G._adjacency_matrix, expected)

    # In S3 with two involutory generators, out-degree per node is 2 in the uncolored digraph
    assert np.all(G._adjacency_matrix.sum(axis=1) == 2)

def test_c4_rotation_inverse_folding_in_tensor(c4_generator):
    e, r = c4_generator
    # Only one generator: r (not an involution), but steps include r and r^{-1}
    G = Group([r], name="C4")

    mats = G._adjacency_tensor
    assert set(mats.keys()) == set(G._generators) == {r}

    M = mats[r]
    n = G.order
    # For a nice simple case, we have circular Cayley graph.
    assert np.all(M.sum(axis=1) == 1)
    assert np.all(M.sum(axis=0) == 1)

    # The uncolored adjacency is the same here (only one slice), still row-sum 2
    A = G._adjacency_matrix
    assert np.array_equal(A, M)
    assert np.all(A.sum(axis=1) == 1)

def test_building_with_redundant_generator_yields_same_elements_but_denser_graph(s3_generators):
    # Minimal S3 generators: s=(01), t=(12)
    e, s, t = s3_generators

    # Choose a redundant generator that is NOT the inverse of s or t to avoid label collisions.
    # Use g3 = t * s = (0 2 1); its inverse is (0 1 2), neither equals s or t.
    g3 = t * s

    G_min = Group([s, t])
    G_red = Group([s, t, g3])
    print(G_red.operations)
    print(G_min.operations)

    # Same group elements / same order
    assert set(G_red._operations) == set(G_min._operations)
    assert G_red.order == G_min.order == 6

    # Uncolored adjacency matrices
    A_min = G_min._adjacency_matrix
    A_red = G_red._adjacency_matrix
    print(A_red)
    print(A_min)
    assert A_min.shape == A_red.shape

    # With extra generator(s), every edge present in the minimal graph is still present.
    # Hence the redundant graph's adjacency (counts) dominates element-wise.
    print(G_red._adjacency_tensor)
    print(G_min._adjacency_tensor)
    assert (A_red >= A_min).all()

    # Row sums equal the number of "steps" used during construction:
    # steps = set(gens ∪ gens^{-1}) \ {identity}
    steps_min = {g.to_str() for g in (s, t, s.inv(), t.inv()) if g != e}
    steps_red = {g.to_str() for g in (s, t, g3, s.inv(), t.inv(), g3.inv()) if g != e}
    assert A_min.sum(axis=1).tolist() == [len(steps_min)] * G_min.order
    assert A_red.sum(axis=1).tolist() == [len(steps_red)] * G_red.order

    # And the redundant graph is strictly denser (strictly larger out-degree)
    assert len(steps_red) > len(steps_min)



